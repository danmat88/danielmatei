rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // The Living Sky: one public counter. Anyone may read it; writes may
    // only ever increment it by exactly 1 — nothing else in the database
    // is reachable.
    match /sky/counter {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['n'])
                    && request.resource.data.n == 1;
      allow update: if request.resource.data.keys().hasOnly(['n'])
                    && request.resource.data.n == resource.data.n + 1;
      allow delete: if false;
    }

    // FORGE orders. Anyone may CREATE a well-formed order (contact-form
    // pattern) and GET one back by its code. Status only ever advances
    // server-side (Admin SDK / a Cloud Function), never from the client.
    match /orders/{code} {
      allow get: if true;
      allow list: if false;
      allow create: if request.resource.data.keys().hasOnly(
                        ['code', 'project', 'features', 'timeline', 'budget',
                         'email', 'estimate', 'stack', 'status', 'createdAt'])
                    && request.resource.data.code == code
                    && request.resource.data.status == 'received'
                    && request.resource.data.createdAt == request.time
                    && request.resource.data.project is string
                    && request.resource.data.project.size() < 80
                    && request.resource.data.features is string
                    && request.resource.data.features.size() < 2000
                    && request.resource.data.email is string
                    && request.resource.data.email.size() < 200
                    && request.resource.data.estimate is string
                    && request.resource.data.estimate.size() < 80
                    && request.resource.data.stack is list
                    && request.resource.data.stack.size() < 12;
      allow update, delete: if false;
    }
  }
}
